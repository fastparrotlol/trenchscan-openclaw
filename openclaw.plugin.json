{
  "id": "trenchscan",
  "name": "TrenchScan",
  "version": "1.2.0",
  "description": "Solana pump.fun token scanner — 22 AI tools for analysis, wallet intel, autonomous trading, position management + realtime KOL/bundle/smart-money alerts",
  "skills": ["skills/trenchscan"],
  "configSchema": {
    "type": "object",
    "required": ["apiKey", "hookToken"],
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "TrenchScan API key (tier: agent)"
      },
      "apiUrl": {
        "type": "string",
        "default": "https://trenchscan.lol",
        "description": "REST API base URL"
      },
      "wsUrl": {
        "type": "string",
        "default": "wss://trenchscan.lol/api/v1/ws",
        "description": "WebSocket URL"
      },
      "hookToken": {
        "type": "string",
        "description": "OpenClaw hook bearer token"
      },
      "hookBaseUrl": {
        "type": "string",
        "default": "http://localhost:3000",
        "description": "OpenClaw gateway URL"
      },
      "alertChannels": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["kol_trades", "bundles"],
        "description": "WS channels to subscribe for alerts"
      },
      "minMcap": {
        "type": "number",
        "default": 0,
        "description": "Minimum market cap filter for token events"
      },
      "maxMcap": {
        "type": "number",
        "default": 0,
        "description": "Maximum market cap filter (0 = no limit)"
      },
      "batchWindowSec": {
        "type": "number",
        "default": 30,
        "description": "Batching window in seconds (0 = instant)"
      },
      "rpcUrl": {
        "type": "string",
        "default": "https://api.mainnet-beta.solana.com",
        "description": "Solana RPC URL for trading transactions"
      },
      "dataDir": {
        "type": "string",
        "default": "./data",
        "description": "Directory for wallet, strategy, position, and trade persistence"
      },
      "tradingEnabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable trading module (buy/sell/strategies)"
      },
      "feeWallet": {
        "type": "string",
        "description": "Platform fee recipient wallet address (default: TrenchScan fee wallet)"
      },
      "feeBps": {
        "type": "number",
        "default": 50,
        "description": "Platform fee in basis points (default: 50 = 0.5%)"
      },
      "jitoTipLamports": {
        "type": "number",
        "default": 200000,
        "description": "Jito MEV tip in lamports (default: 200000 = 0.0002 SOL)"
      },
      "withdrawConfig": {
        "type": "object",
        "description": "Auto-withdrawal config: {enabled, destination, mode, percent?, afterEveryTrade}",
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "destination": { "type": "string", "description": "Destination wallet address" },
          "mode": { "type": "string", "enum": ["all_profit", "percent"], "default": "all_profit" },
          "percent": { "type": "number", "description": "Percentage of profit to withdraw (if mode=percent)" },
          "afterEveryTrade": { "type": "boolean", "default": false, "description": "Auto-withdraw after each sell" }
        }
      },
      "alertFilters": {
        "type": "object",
        "description": "Alert filtering by mint/symbol whitelist/blacklist",
        "properties": {
          "mints": { "type": "array", "items": { "type": "string" }, "description": "Whitelist: only show alerts for these mints" },
          "symbols": { "type": "array", "items": { "type": "string" }, "description": "Whitelist: only show alerts for these symbols (case-insensitive)" },
          "excludeMints": { "type": "array", "items": { "type": "string" }, "description": "Blacklist: never show alerts for these mints" }
        }
      },
      "rateLimitRpm": {
        "type": "number",
        "default": 60,
        "description": "API rate limit in requests per minute (for risk checks)"
      }
    }
  },
  "uiHints": {
    "apiKey": { "label": "API Key", "sensitive": true },
    "hookToken": { "label": "Hook Token", "sensitive": true },
    "apiUrl": { "label": "API URL", "placeholder": "https://trenchscan.lol" },
    "wsUrl": { "label": "WebSocket URL", "placeholder": "wss://trenchscan.lol/api/v1/ws" },
    "rpcUrl": { "label": "Solana RPC URL", "placeholder": "https://api.mainnet-beta.solana.com" },
    "tradingEnabled": { "label": "Enable Trading" },
    "feeWallet": { "label": "Fee Wallet", "placeholder": "Solana wallet address" },
    "dataDir": { "label": "Data Directory", "placeholder": "./data" }
  }
}
